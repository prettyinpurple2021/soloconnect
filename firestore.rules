rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "prettyinpurple2021@gmail.com"
      );
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.bio is string && data.bio.size() <= 1000;
    }

    function isValidPost(data) {
      return data.content is string && data.content.size() <= 10000 &&
             data.authorId is string;
    }

    function isValidGroup(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.creatorId is string;
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.creatorId is string;
    }

    // ===============================================================
    // COLLECTION MATCH BLOCKS
    // ===============================================================

    // Root Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['connections', 'pendingConnections', 'sentRequests', 'endorsements', 'xp', 'level', 'momentum', 'blockedUsers', 'savedPosts']));
      
      match /private/info {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && incoming().authorId == request.auth.uid && isValidPost(incoming());
      allow update: if (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'images', 'tags', 'updatedAt'])) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentCount']));
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && incoming().creatorId == request.auth.uid && isValidGroup(incoming());
      allow update: if isOwner(existing().creatorId) || (isSignedIn() && (incoming().diff(existing()).affectedKeys().hasOnly(['members', 'moderators']) || incoming().diff(existing()).affectedKeys().hasOnly(['goals', 'resources'])));
      allow delete: if isOwner(existing().creatorId) || isAdmin();

      match /goals/{goalId} {
        allow read: if isSignedIn();
        allow write: if isVerified();
      }
      match /resources/{resId} {
        allow read: if isSignedIn();
        allow write: if isVerified();
      }
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && incoming().creatorId == request.auth.uid && isValidEvent(incoming());
      allow update: if isOwner(existing().creatorId) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['attendees', 'waitlist']));
      allow delete: if isOwner(existing().creatorId) || isAdmin();

      match /checkins/{checkinId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && incoming().userId == request.auth.uid;
      }
    }

    match /notifications/{notifId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn(); 
    }

    match /chats/{chatId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());

      match /messages/{messageId} {
        allow get, list, create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
      }
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /vouches/{vouchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().sourceId == request.auth.uid;
    }

    match /marketplace_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().sellerId == request.auth.uid;
      allow update, delete: if isOwner(existing().sellerId) || isAdmin();
    }

    match /opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isOwner(existing().userId) || isAdmin();
    }

    match /personal_events/{eventId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isOwner(incoming().userId);
      allow update, delete: if isOwner(existing().userId);
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
