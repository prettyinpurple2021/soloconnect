rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "prettyinpurple2021@gmail.com" && request.auth.token.email_verified == true));
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function authorIdUnchanged() {
      return !('authorId' in request.resource.data) || request.resource.data.authorId == request.auth.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'displayName', 'email', 'createdAt']) &&
             isValidString('displayName', 1, 100) &&
             isValidString('email', 3, 255) &&
             request.resource.data.createdAt is timestamp &&
             isValidOptionalString('bio', 0, 1000) &&
             isValidOptionalString('location', 0, 200) &&
             isValidOptionalString('photoURL', 0, 2000) &&
             (!('skills' in request.resource.data) || request.resource.data.skills is list) &&
             (!('links' in request.resource.data) || request.resource.data.links is map) &&
             (!('connections' in request.resource.data) || request.resource.data.connections is list) &&
             (!('savedPosts' in request.resource.data) || request.resource.data.savedPosts is list) &&
             (!('blockedUsers' in request.resource.data) || request.resource.data.blockedUsers is list) &&
             (!('portfolio' in request.resource.data) || request.resource.data.portfolio is list) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isValidPost() {
      return hasRequiredFields(['authorId', 'authorName', 'content', 'createdAt']) &&
             isValidString('authorId', 1, 100) &&
             isValidString('authorName', 1, 100) &&
             isValidString('content', 0, 5000) &&
             request.resource.data.createdAt is timestamp &&
             (!('likes' in request.resource.data) || request.resource.data.likes is list) &&
             (!('images' in request.resource.data) || request.resource.data.images is list) &&
             (!('tags' in request.resource.data) || request.resource.data.tags is list) &&
             (!('groupId' in request.resource.data) || request.resource.data.groupId is string) &&
             (!('commentCount' in request.resource.data) || request.resource.data.commentCount is number) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isValidComment() {
      return hasRequiredFields(['postId', 'authorId', 'authorName', 'content', 'createdAt']) &&
             isValidString('postId', 1, 100) &&
             isValidString('authorId', 1, 100) &&
             isValidString('authorName', 1, 100) &&
             isValidString('content', 1, 2000) &&
             request.resource.data.createdAt is timestamp &&
             (!('parentId' in request.resource.data) || isValidString('parentId', 1, 100)) &&
             (!('replyCount' in request.resource.data) || request.resource.data.replyCount is number) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isValidGroup() {
      return hasRequiredFields(['name', 'description', 'creatorId', 'createdAt']) &&
             isValidString('name', 1, 100) &&
             isValidString('description', 1, 2000) &&
             isValidString('creatorId', 1, 100) &&
             request.resource.data.createdAt is timestamp &&
             (!('members' in request.resource.data) || request.resource.data.members is list) &&
             (!('moderators' in request.resource.data) || request.resource.data.moderators is list) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isValidEvent() {
      return hasRequiredFields(['title', 'description', 'date', 'creatorId', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             isValidString('description', 1, 2000) &&
             isValidString('creatorId', 1, 100) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.date is timestamp &&
             (!('location' in request.resource.data) || request.resource.data.location is string) &&
             (!('coverImage' in request.resource.data) || request.resource.data.coverImage is string) &&
             (!('groupId' in request.resource.data) || request.resource.data.groupId is string) &&
             (!('attendees' in request.resource.data) || request.resource.data.attendees is list) &&
             (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function isValidNotification() {
      return hasRequiredFields(['userId', 'type', 'sourceUserId', 'sourceUserName', 'content', 'link', 'read', 'createdAt']) &&
             isValidString('userId', 1, 100) &&
             isValidString('type', 1, 50) &&
             request.resource.data.type in ['connection_request', 'comment', 'event_invite'] &&
             isValidString('sourceUserId', 1, 100) &&
             isValidString('sourceUserName', 1, 100) &&
             isValidString('content', 1, 500) &&
             isValidString('link', 1, 500) &&
             request.resource.data.read is bool &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidChat() {
      return hasRequiredFields(['participants', 'createdAt', 'updatedAt']) &&
             request.resource.data.participants is list &&
             request.resource.data.participants.size() == 2 &&
             request.resource.data.participants.hasAll([request.auth.uid]) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp &&
             (!('lastMessage' in request.resource.data) || request.resource.data.lastMessage is string) &&
             (!('lastMessageAt' in request.resource.data) || request.resource.data.lastMessageAt is timestamp) &&
             (!('unreadCount' in request.resource.data) || request.resource.data.unreadCount is map);
    }

    function isValidMessage() {
      return hasRequiredFields(['chatId', 'senderId', 'content', 'createdAt', 'read']) &&
             isValidString('chatId', 1, 100) &&
             request.resource.data.senderId == request.auth.uid &&
             isValidString('content', 1, 5000) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.read is bool;
    }

    function isValidPersonalEvent() {
      return hasRequiredFields(['userId', 'title', 'date', 'createdAt']) &&
             isValidString('userId', 1, 100) &&
             isValidString('title', 1, 200) &&
             request.resource.data.date is timestamp &&
             request.resource.data.createdAt is timestamp &&
             (!('description' in request.resource.data) || request.resource.data.description is string) &&
             (!('type' in request.resource.data) || request.resource.data.type in ['event', 'reminder', 'task']) &&
             (!('recurrence' in request.resource.data) || request.resource.data.recurrence in ['none', 'daily', 'weekly', 'monthly']) &&
             (!('completed' in request.resource.data) || request.resource.data.completed is bool) &&
             (!('completedDates' in request.resource.data) || request.resource.data.completedDates is list) &&
             (!('excludedDates' in request.resource.data) || request.resource.data.excludedDates is list);
    }

    function isValidInsight() {
      return hasRequiredFields(['userId', 'agentId', 'agentName', 'content', 'createdAt']) &&
             isValidString('userId', 1, 100) &&
             isValidString('agentId', 1, 100) &&
             isValidString('agentName', 1, 100) &&
             isValidString('content', 1, 10000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidDocument() {
      return hasRequiredFields(['userId', 'title', 'content', 'type', 'createdAt', 'updatedAt']) &&
             isValidString('userId', 1, 100) &&
             isValidString('title', 1, 200) &&
             isValidString('content', 1, 50000) &&
             request.resource.data.type in ['ideation', 'document'] &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isAuthenticated() && isValidUser() && uidUnchanged() &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (
                      isOwner(userId) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connections']) ||
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['blockedUsers'])
                    );
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost() && authorIdUnchanged();
      allow update: if isAuthenticated() && isValidPost() &&
                    (
                      // Owner can update content
                      (request.auth.uid == resource.data.authorId &&
                       request.resource.data.authorId == resource.data.authorId &&
                       request.resource.data.createdAt == resource.data.createdAt)
                      ||
                      // Anyone can like/unlike (only 'likes' array changes)
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
                      ||
                      // Anyone can comment (only 'commentCount' changes)
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount']))
                    );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.authorId ||
        (
          'groupId' in resource.data &&
          (
            request.auth.uid == get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.creatorId ||
            request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.moderators
          )
        )
      );
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComment() && authorIdUnchanged();
      allow update: if isAuthenticated() && isValidComment() &&
                    (
                      (request.auth.uid == resource.data.authorId &&
                       request.resource.data.authorId == resource.data.authorId &&
                       request.resource.data.createdAt == resource.data.createdAt)
                      ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount']))
                    );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
    }

    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGroup() &&
                    request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidGroup() &&
                    (
                      // Creator can update everything
                      (request.auth.uid == resource.data.creatorId &&
                       request.resource.data.creatorId == resource.data.creatorId &&
                       request.resource.data.createdAt == resource.data.createdAt)
                      ||
                      // Moderators can remove members (but not the creator)
                      (
                        request.auth.uid in resource.data.moderators &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                        request.resource.data.members.hasAll([resource.data.creatorId])
                      )
                      ||
                      // Regular members can only join/leave themselves
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
                        request.resource.data.moderators == resource.data.moderators &&
                        (
                          // Joining
                          (request.resource.data.members.size() == resource.data.members.size() + 1 &&
                           request.resource.data.members.hasAll(resource.data.members) &&
                           request.auth.uid in request.resource.data.members)
                          ||
                          // Leaving
                          (request.resource.data.members.size() == resource.data.members.size() - 1 &&
                           resource.data.members.hasAll(request.resource.data.members) &&
                           !(request.auth.uid in request.resource.data.members))
                        )
                      )
                    );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidEvent() &&
                    request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && isValidEvent() &&
                    (
                      // Creator can update details
                      (request.auth.uid == resource.data.creatorId &&
                       request.resource.data.creatorId == resource.data.creatorId &&
                       request.resource.data.createdAt == resource.data.createdAt)
                      ||
                      // Anyone can RSVP (only 'attendees' array changes)
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendees']))
                    );
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidNotification() &&
                    request.resource.data.sourceUserId == request.auth.uid;
      allow update: if isAuthenticated() && isValidNotification() &&
                    request.auth.uid == resource.data.userId &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && isValidChat();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage();
        allow update: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    match /personal_events/{eventId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidPersonalEvent() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPersonalEvent() && request.auth.uid == resource.data.userId && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /insights/{insightId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidInsight() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /documents/{docId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidDocument() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidDocument() && request.auth.uid == resource.data.userId && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
  }
}
