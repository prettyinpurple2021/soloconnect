rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // PILLAR 3: Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // PILLAR 2: Hardened Global Helpers
    // ===============================================================
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "prettyinpurple2021@gmail.com"
      );
    }

    // ===============================================================
    // Validation Blueprints (Anti-Update-Gap)
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.createdAt is timestamp &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('deleted' in data) || data.deleted is bool);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt is timestamp &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 10));
    }

    function isValidComment(data) {
      return data.keys().hasAll(['postId', 'authorId', 'authorName', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    function isValidOpportunity(data) {
      return data.keys().hasAll(['userId', 'userName', 'title', 'description', 'type', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.type in ['hiring', 'selling', 'buying', 'collaboration'] &&
             data.status in ['open', 'closed'] &&
             data.createdAt is timestamp;
    }

    function isValidVouch(data) {
      return data.keys().hasAll(['toUserId', 'fromUserId', 'fromUserName', 'content', 'category', 'createdAt']) &&
             data.fromUserId == request.auth.uid &&
             data.toUserId != request.auth.uid && // No self-vouching
             data.content is string && data.content.size() <= 1000 &&
             data.category in ['technical', 'equity', 'vision', 'execution'] &&
             data.createdAt is timestamp;
    }

    function isValidMail(data) {
      return data.keys().hasAll(['to', 'message']) &&
             data.to == request.auth.token.email &&
             data.message.keys().hasAll(['subject', 'html']) &&
             data.message.subject is string && data.message.subject.size() <= 200 &&
             data.message.html is string && data.message.html.size() <= 50000;
    }

    // ===============================================================
    // Collection Match Blocks
    // ===============================================================

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.deleted != true;
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId) && (
        (!('deleted' in existing()) || existing().deleted == false) &&
        (
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'bio', 'location', 'photoURL', 'coverURL', 'skills', 'endorsements', 'links', 'portfolio', 'goals', 'updatedAt']) && incoming().updatedAt == request.time) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['deleted', 'updatedAt']) && incoming().deleted == true && incoming().updatedAt == request.time) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['connections', 'pendingConnections', 'sentRequests', 'blockedUsers']))
        )
      ) || (
        isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['endorsements', 'connections', 'pendingConnections', 'sentRequests'])
      );
    }

    match /opportunities/{oppId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(oppId) && isValidOpportunity(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().updatedAt == request.time) ||
        (isValidOpportunity(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'type', 'tags', 'budget', 'updatedAt']) && incoming().updatedAt == request.time)
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidPost(incoming()) && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'images', 'tags', 'updatedAt']) && incoming().updatedAt == request.time) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes'])) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['commentCount']));
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidComment(incoming()) && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt']) && incoming().updatedAt == request.time) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['replyCount']));
      allow delete: if isOwner(existing().authorId) || isAdmin();
    }

    match /vouches/{vouchId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidVouch(incoming()) && incoming().createdAt == request.time;
      allow delete: if isOwner(existing().fromUserId) || isOwner(existing().toUserId) || isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && request.auth.uid == incoming().creatorId && incoming().createdAt == request.time;
      allow update: if (isOwner(existing().creatorId)) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['members', 'moderators']));
      allow delete: if isOwner(existing().creatorId) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && incoming().participants.hasAll([request.auth.uid]) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid in existing().participants && incoming().updatedAt == request.time;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && incoming().senderId == request.auth.uid && incoming().createdAt == request.time;
      }
    }

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn() && incoming().sourceUserId == request.auth.uid && incoming().createdAt == request.time;
    }

    match /mail/{mailId} {
      allow create: if isVerified() && isValidMail(incoming());
      allow read: if isVerified() && resource.data.to == request.auth.token.email;
    }
  }
}
